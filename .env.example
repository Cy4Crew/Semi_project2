# Web API
API_HOST=0.0.0.0
API_PORT=8000
APP_NAME=Malware Sandbox Platform

# Storage
SAMPLES_DIR=./samples
ARTIFACTS_DIR=./artifacts
YARA_RULES_DIR=./rules
REPORT_DB_PATH=./artifacts/reports.db

# Analysis limits
SAMPLE_TIMEOUT_SECONDS=60
MAX_UPLOAD_BYTES=624924760
MAX_ARCHIVE_FILES=100
MAX_ARCHIVE_EXEC_MEMBERS=8
MAX_ZIP_TOTAL_UNCOMPRESSED_BYTES=838860800
MAX_ZIP_ENTRY_UNCOMPRESSED_BYTES=209715200
MAX_ZIP_COMPRESSION_RATIO=250.0
MAX_ZIP_DEPTH_HINT=3
REJECT_ENCRYPTED_ARCHIVES=true
ALLOWED_UPLOAD_EXTENSIONS=.zip
ALLOWED_UPLOAD_CONTENT_TYPES=application/zip,application/x-zip-compressed,multipart/x-zip
ENTROPY_THRESHOLD=7.2

# Local sandbox fallback
SANDBOX_MEMORY_LIMIT_MB=256
SANDBOX_FILE_SIZE_LIMIT_MB=32
SANDBOX_MAX_PROCESSES=16
SANDBOX_DROP_PRIVILEGES=true
SANDBOX_DISABLE_NETWORK=true
SANDBOX_NETWORK_SAMPLE_INTERVAL_MS=250
SANDBOX_RUNTIME_ROOT=/tmp/malware_sandbox
SANDBOX_REQUIRE_DYNAMIC_SUCCESS=true

# VMware bridge mode
SANDBOX_BACKEND=vmware-bridge
SANDBOX_BRIDGE_URL=http://host.docker.internal:9080
SANDBOX_VM_NAME=win10x64
SANDBOX_VM_SNAPSHOT=clean
SANDBOX_JOB_TIMEOUT_SECONDS=180

# Optional multi-VM routing
SANDBOX_BRIDGE_URLS=
SANDBOX_VM_NAMES=

# Optional external tooling
ENABLE_PCAP=false
SURICATA_BINARY=
SURICATA_RULES_PATH=./rules/suricata.rules
VOLATILITY3_BINARY=
PROCDUMP_PATH=C:\Tools\Sysinternals\procdump64.exe
MONITOR_LOGS_DIR=C:\analysis\monitor

# Worker and DB behavior
ANALYSIS_WORKER_COUNT=2
REPORT_DB_BUSY_TIMEOUT_MS=5000

# Verdict thresholds
VERDICT_CLEAN_MAX=19
VERDICT_REVIEW_MAX=39
VERDICT_SUSPICIOUS_MAX=69

SANDBOX_BRIDGE_HEALTH_TTL_SECONDS=10
SANDBOX_VM_SLOT_COOLDOWN_SECONDS=20
SANDBOX_BRIDGE_SUBMIT_RETRIES=2



#Additional readiness and recursive execution settings were added in this patch. See scripts/host_bridge.env.example for bridge-side readiness probe values and guest_tools/guest_agent.py for recursive dropped-file execution limits.


# Observability
ANALYSIS_METRICS_ENABLED=true

BRIDGE_AUTH_TOKEN=
ARTIFACT_ACCESS_TOKEN=
ALLOWED_UPLOAD_MAGIC_HEX=504b0304,504b0506,504b0708
ANALYSIS_MAX_RETRIES=2
ANALYSIS_RETRY_BACKOFF_SECONDS=2.0
DEAD_LETTER_DIR=artifacts/dead_letter
SANDBOX_BRIDGE_RETRY_BACKOFF_SECONDS=2.0

BENIGN_WHITELIST_PATH=rules/benign_whitelist.json
BENIGN_WHITELIST_ENABLED=true
REPORTS_DEFAULT_PAGE_SIZE=30
REPORTS_MAX_PAGE_SIZE=200
