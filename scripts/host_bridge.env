VMX_PATH=C:\win10x64\win10x64.vmx
VMRUN_PATH=C:\PROGRA~2\VMware\VMware Workstation\vmrun.exe
PYTHON_BIN=python

BRIDGE_WORK_DIR=host_bridge\workspace
BRIDGE_SHARED_DIR=host_bridge\workspace\shared

DEFAULT_VM_NAME=win10x64
DEFAULT_SNAPSHOT=clean
DEFAULT_TIMEOUT=180
SOFT_STOP_WAIT_SECONDS=20

BRIDGE_PORT=9080
DOCKER_API_PORT=8000
DOCKER_CONTAINER_API_PORT=8000
DOCKER_API_HOST=0.0.0.0

DOCKER_SANDBOX_BACKEND=vmware-bridge
DOCKER_SANDBOX_BRIDGE_URL=http://host.docker.internal:9080
DOCKER_SANDBOX_VM_NAME=win10x64
DOCKER_SANDBOX_VM_SNAPSHOT=clean
DOCKER_SANDBOX_JOB_TIMEOUT_SECONDS=180
DOCKER_SANDBOX_DISABLE_NETWORK=false
DOCKER_SANDBOX_REQUIRE_DYNAMIC_SUCCESS=true

DOCKER_ENABLE_PCAP=false
DOCKER_SURICATA_BINARY=
DOCKER_SURICATA_RULES_PATH=./rules/suricata.rules
DOCKER_VOLATILITY3_BINARY=
DOCKER_MONITOR_LOGS_DIR=C:/analysis/monitor
DOCKER_REPORT_DB_PATH=./artifacts/reports.db

SANDBOX_BRIDGE_HEALTH_TTL_SECONDS=10
SANDBOX_VM_SLOT_COOLDOWN_SECONDS=20
SANDBOX_BRIDGE_SUBMIT_RETRIES=2

GUEST_HEARTBEAT_TTL_SECONDS=45
GUEST_READY_TIMEOUT_SECONDS=120
SNAPSHOT_PROBE_TIMEOUT_SECONDS=60

ANALYSIS_METRICS_ENABLED=true

BRIDGE_AUTH_TOKEN=
